#!/usr/bin/env zsh

gh-pr-reviews() {
  emulate -L zsh
  setopt err_return pipe_fail no_unset extended_glob

  local -a req_opts args api
  local repo="" id opt GH_TOKEN_LOCAL

  req_opts=(
    --retry-all-errors
    --retry 4
    --connect-timeout 15
    -H "Accept: application/vnd.github+json"
    -H "X-GitHub-Api-Version: 2022-11-28"
  )

  args=()

  while getopts "haR:" opt; do
    case "$opt" in
      a)
        if [[ -z "${GH_TOKEN:-}" ]]; then
          GH_TOKEN_LOCAL="$(
            grep -oE 'oauth_token: *.*' ~/.config/gh/hosts.yml |
              sed 's/oauth_token: *//' |
              tail -n1
          )"
        else
          GH_TOKEN_LOCAL="$GH_TOKEN"
        fi

        req_opts+=(-H "Authorization: Bearer ${GH_TOKEN_LOCAL}")
        ;;

      R)
        repo="$OPTARG"
        ;;

      h)
        printf 'Usage: %s [Options] [number]\n' "${0:t}"
        echo 'show github pull request reviews'
        echo
        printf '%s\n' \
          'Options:' \
          '    -a                 try using GH_TOKEN / gh hosts.yml token' \
          '    -R owner/repo       repository, defaults to gh repo set-default -v' \
          '    -h                 show help'
        return 0
        ;;

      \?)
        printf '%s: parse args failed\n' "$0" >&2
        return 2
        ;;
    esac
  done

  shift $((OPTIND - 1))

  if (( $# > 1 )); then
    printf '%s: unexpected arg %q\n' "$0" "$2" >&2
    return 2
  fi

  repo="${repo##(http(|s)://)#(www.)#github.com/}"

  if [[ -z "$repo" ]]; then
    repo="$(gh repo set-default -v)" || return
  fi

  if (( $# == 1 )); then
    id="$1"
  else
    id="$(gh pr view --json number | jq .number)" || return
  fi

  hash gh curl jq || return

  api=(
    "https://api.github.com/repos/$repo/issues/$id/comments"
    "https://api.github.com/repos/$repo/pulls/$id"
    "https://api.github.com/repos/$repo/pulls/$id/comments"
    "https://api.github.com/repos/$repo/pulls/$id/reviews"
  )

  printf 'api:'
  printf ' %q' "${api[@]}"
  printf '\n'

  curl --no-progress-meter "${req_opts[@]}" -- "${api[@]}" |
    jq -nr '
{
  "+1":       "👍",
  "-1":       "👎",
  "laugh":    "😄",
  "hooray":   "🎉",
  "confused": "❓",
  "heart":    "❤️",
  "rocket":   "🚀",
  "eyes":     "👀",
} as $reactions |

def fi($n): tostring | .+" "*($n-length);
def csim(seq): [seq]|"\u001b[\(join(";"))m";
def csim: csim(empty);
def title: .[:1]+(.[1:]|ascii_downcase);
def bool($x): $x | length | . != 0 and . != null;
def rtrim: sub("\\s+$"; "");
def clean_csi: gsub("\u001b\\[(\\d+(;\\d+)*)m"; "");
def differ:
  if startswith("+") then
    csim(32)+.+csim
  elif startswith("-") then
    csim(31)+.+csim
  elif startswith("@@") then
    csim(36)+.+csim
  elif startswith("%") then
    csim(33)+.+csim
  end
  ;
def bodyer(lines):
  foreach lines as $line ({code:false};
    .cur = ($line | test("^ *```[^`]*$")) | if .cur then .code |= not end;
    if .code or .cur then
      [csim(2,48,5,236)+"\u001b[K"+$line+csim(49,22)]
    elif $line | startswith("> ") or .==">" then
      [csim(38,5,251)+"│ "+$line[2:]+csim, true]
    else
      [$line, true]
    end
  ) | . as [$line, $render] | $line |
  if $render then
    .
    | gsub("(?<x>(?<!\\*)\\*[^* ](\\\\|[^`])*?(?<![* ])\\*)"; csim(3)+.x+csim(23))
    | gsub("(?<x>(?<!\\*)\\*\\*[^* ](\\\\|[^`])*?(?<![* ])\\*\\*)"; csim(1)+.x+csim(22))
    | gsub("(?<x>(?<!\\*)\\*\\*\\*[^* ](\\\\|[^`])*?(?<![* ])\\*\\*\\*)"; csim(1,3)+.x+csim(23,22))
    | gsub("(?<x>(?<!~)~~[^~ ](\\\\|[^`])*?(?<![~ ])~~)"; csim(9)+.x+csim(29))
    | gsub("(?<!`)(?<q>`+)(?<x>( *)[^ ](?:(?!\\3\\1).)*\\3)\\1"; csim(2,8,48,5,236)+.q+csim(28)+(.x|clean_csi)+csim(8)+.q+csim(28,49,22)+"\u001b[K")
  end
  ;
def diff_title:
  first(reverse[] | select(test("^.\\S.{3}"))[1:75])
  ;
def expected($ty):
  if type != $ty then
    debug | error("unexpected input type \(type), expected a \($ty)")
  end
  ;
def pull_body_pack:
  if has("body")? // false then
    if has("title") then .body = .title+"\n\n"+.body end |
    if .merged then .state = "merged" end |
    if .draft and .state == "open" then .state = "draft" end |
    [.]
  end;
def patch_formatter:
  expected("array") |
  if length > 50 then
    .[4:length-20] |= ["% Folded \(length) lines %\(" "+diff_title // "")"]
  elif length == 0 or . == [""] then
    ["% No patch provided"]
  end
  ;
def elap:
  [
    (now, fromdate)
    | strftime("%s")
    | tonumber
  ]
  | first-last
  | [
      ., (
        ./60 | ., (
          ./60 | ., (
            ./24 | ., (
              ./30.4375 | ., (
                ./12)))))
      | floor
    ]
  | [" seconds", " minutes", "h", "d", " months", " years"] as $label
  | last(to_entries[]
    | [.value, $label[.key]]
    | select(first > 1)
    | join("")
    ) // ""
  ;
def clean:
  if type == "string" then
    rtrim
  end
  ;
def association:
  if .author_association and .author_association != "NONE" then
    " (\(.author_association|title))"
  else
    ""
  end;
def state:
  .state | if . then
    " "+(ascii_downcase
      | if endswith("requested") then
        csim(31)+.+csim(39)
      elif endswith("approved") then
        csim(32)+.+csim(39)
      end)
  else
    ""
  end
  ;
def reactions:
  [.reactions
  | values
  | to_entries[]
  | "\(.value | select(. != 0)) \($reactions[.key] | values)"
  ] | join(" ") | select(bool(.))
  ;
def meta:
  .meta
  | select(.additions)
  | [csim(32)+"+\(.additions)"
    ,csim(31)+"-\(.deletions)"
    ,"(\(.changed_files) files)"
    ,(select(.mergeable_state == "dirty") | csim(1)+"mergeable:\(csim(22,33))dirty")
    ,(select(.auto_merge) | csim(1)+"automerge:\(.auto_merge)")
    ,"branch:"+.head.ref]
  | join(csim+" ")+csim
  ;
"\u0000topLevel" as $top |
reduce (inputs | pull_body_pack | expected("array"))[] as $review ({};
  .[$review.diff_hunk // $top] += [$review | {
    user: .user.login,
    body,
    created_at: (.created_at // .submitted_at // "9999-12-31T23:59:59Z"),
    updated_at,
    html_url,
    author_association,
    path,
    state,
    reactions,
    meta: {
      additions,
      deletions,
      changed_files,
      mergeable_state,
      auto_merge,
      head,
    },
  }]
)
| .[][].body |= clean
| to_entries
| map(if .key == $top then .value = (.value[] | select(.state != "COMMENTED" or bool(.body)) | [.]) end)
| sort_by(.value[0] | [(.created_at | fromdate), .state])[]
|
( (.value[0].path | values | "", .)
, (.key | select(. != $top) | [splits("\n")] | patch_formatter[] | "│ "+differ)
, (.value[]
  | (if .updated_at and .updated_at != .created_at then
      " update at \(.updated_at|elap)" else ""
    end) as $update
  | "\n"+csim(1)+("\(.user)\(association)\(state)"|fi(50))+csim+" • \((.created_at|elap)+$update)"
  , meta
  , reactions
  , ""
  , if bool(.body) then
      "  "+bodyer(.body | splits(" *\r?\n"))
    else
      "  "+csim(90)+"No body provided"+csim
    end
  , ""
  , csim(90)+"View the full review: "+.html_url+csim
  )
, (select(.value[0].path != null) | "", "─"*70)
)
'
}

gh-pr-reviews "$@"

[Unit]
Description=OpenCode Web
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h
Environment=HOME=%h
Environment=XDG_CONFIG_HOME=%h/.config
ExecStart=%h/.local/share/mise/shims/opencode web
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target

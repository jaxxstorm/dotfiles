#!/usr/bin/env bash
set -euo pipefail

mkdir -p "$HOME/.local/bin"
export PATH="$HOME/.local/bin:$PATH"

SUDO=""
if [ "$(id -u)" -ne 0 ] && command -v sudo >/dev/null 2>&1; then
  SUDO="sudo"
fi

# Install Homebrew on macOS if missing.
{{- if eq .chezmoi.os "darwin" }}
if ! command -v brew >/dev/null 2>&1; then
  NONINTERACTIVE=1 /bin/bash -c \
    "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Install GnuPG and macOS pinentry support if missing.
if ! command -v gpgconf >/dev/null 2>&1; then
  brew install gnupg pinentry-mac
fi
{{- end }}

# Install zsh on Linux if missing.
{{- if eq .chezmoi.os "linux" }}
if ! command -v zsh >/dev/null 2>&1; then
  if command -v apt-get >/dev/null 2>&1; then
    $SUDO apt-get update
    $SUDO apt-get install -y zsh
  elif command -v dnf >/dev/null 2>&1; then
    $SUDO dnf install -y zsh
  elif command -v yum >/dev/null 2>&1; then
    $SUDO yum install -y zsh
  elif command -v pacman >/dev/null 2>&1; then
    $SUDO pacman -Sy --noconfirm zsh
  elif command -v apk >/dev/null 2>&1; then
    $SUDO apk add --no-cache zsh
  elif command -v zypper >/dev/null 2>&1; then
    $SUDO zypper --non-interactive install zsh
  else
    echo "Unable to install zsh automatically: unsupported package manager." >&2
    exit 1
  fi
fi

# Install GnuPG and pinentry on Linux if missing.
if ! command -v gpgconf >/dev/null 2>&1; then
  if command -v apt-get >/dev/null 2>&1; then
    $SUDO apt-get update
    $SUDO apt-get install -y gnupg2 pinentry-curses
  elif command -v dnf >/dev/null 2>&1; then
    $SUDO dnf install -y gnupg2 pinentry
  elif command -v yum >/dev/null 2>&1; then
    $SUDO yum install -y gnupg2 pinentry
  elif command -v pacman >/dev/null 2>&1; then
    $SUDO pacman -Sy --noconfirm gnupg pinentry
  elif command -v apk >/dev/null 2>&1; then
    $SUDO apk add --no-cache gnupg pinentry
  elif command -v zypper >/dev/null 2>&1; then
    $SUDO zypper --non-interactive install gpg2 pinentry
  else
    echo "Unable to install GnuPG automatically: unsupported package manager." >&2
    exit 1
  fi
fi
{{- end }}

# Install mise if missing.
if ! command -v mise >/dev/null 2>&1; then
  curl -fsSL https://mise.run | sh
fi

# Install Starship if missing.
if ! command -v starship >/dev/null 2>&1; then
  curl -fsSL https://starship.rs/install.sh | sh -s -- -y -b "$HOME/.local/bin"
fi

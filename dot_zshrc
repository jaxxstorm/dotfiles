# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
zstyle ':omz:update' mode reminder  # just remind me to update when it's time

COMPLETION_WAITING_DOTS="true"

if [ -r "$ZSH/oh-my-zsh.sh" ]; then
  source "$ZSH/oh-my-zsh.sh"
fi

plugins=(git ssh-agent aws)

export PATH="$HOME/.local/bin:$HOME/bin:$HOME/.cargo/bin:$HOME/.tfenv/bin:$HOME/.gobrew/current/bin:$HOME/.gobrew/bin:/opt/homebrew/bin:/opt/homebrew/lib/ruby/gems/3.1.0/bin:/opt/homebrew/opt/ruby/bin:$PATH"

# Starship
if command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
fi

# awsp
alias awsp="source _awsp"

# GPG
# Add the following to your shell init to set up gpg-agent automatically for every shell
export GPG_TTY=$(tty)
if command -v gpgconf >/dev/null 2>&1; then
  gpgconf --launch gpg-agent >/dev/null 2>&1 || true
fi

if [ -d "$HOME/.kube/config.d" ]; then
  kube_configs=("$HOME"/.kube/config.d/*(N))
  if [ ${#kube_configs[@]} -gt 0 ]; then
    export KUBECONFIG="${KUBECONFIG:+$KUBECONFIG:}${(j/:/)kube_configs}"
  fi
fi

export EDITOR=vim
if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate zsh)"
fi
